// 🧠 PART 1: Type Conversion (Most Important Concept)
// 🔹 1. Converting String → Number
// let score = "hitesh"
// let valueInNumber = Number(score)

// 👉 What happens here?

// "hitesh" is not a number
// So JavaScript tries to convert it… and fails

// ✔ Result:

// valueInNumber = NaN
// ❗ What is NaN?
// NaN = Not a Number
// Type is still "number" (weird but true)
// ✅ Examples you MUST remember:
// Input	Output
// "33"	33
// "33abc"	NaN
// "hitesh"	NaN
// true	1
// false	0
// 🔹 2. Converting to Boolean
// let isLoggedIn = "hitesh"
// let booleanIsLoggedIn = Boolean(isLoggedIn)

// 👉 Rule: Anything non-empty = true

// ✅ Examples:
// Value	Boolean
// 1	true
// 0	false
// ""	false
// "hitesh"	true
// 🔹 3. Converting Number → String
// let someNumber = 33
// let stringNumber = String(someNumber)

// ✔ Result:

// "33" (now it's a string)
// ⚡ PART 2: Operations (Math + Behavior)
// 🔹 Basic Math
// 2 + 2   // 4
// 2 - 2   // 0
// 2 * 2   // 4
// 2 ** 3  // 8 (power)
// 2 / 3   // 0.666...
// 2 % 3   // 2 (remainder)
// 🔹 Negative Value
// let value = 3
// let negValue = -value

// ✔ Result:

// -3
// 🧩 PART 3: String Operations (IMPORTANT TRICKY PART)
// let str1 = "hello"
// let str2 = " hitesh"

// let str3 = str1 + str2

// ✔ Output:

// "hello hitesh"
// ⚠️ MOST IMPORTANT INTERVIEW LOGIC
// console.log("1" + 2);      // "12"
// console.log(1 + "2");      // "12"
// console.log("1" + 2 + 2);  // "122"
// console.log(1 + 2 + "2");  // "32"
// 💡 Rule:

// 👉 If string comes first → everything becomes string

// 👉 If numbers come first → normal math first

// 🔥 PART 4: Weird Conversions (VERY IMPORTANT)
// console.log(+true);  // 1
// console.log(+"");    // 0

// 👉 + tries to convert into number

// 🧠 PART 5: Assignment Trick
// num1 = num2 = num3 = 2 + 2

// ✔ All become:

// 4

// 👉 Avoid this in real projects (bad readability)

// 🎮 PART 6: Increment Operator
// let gameCounter = 100
// ++gameCounter;
// console.log(gameCounter);

// ✔ Output:

// 101
// 🔹 Difference (VERY IMPORTANT)
// let x = 5
// let y = ++x  // first increase, then assign

// // x = 6, y = 6
// let x = 5
// let y = x++  // first assign, then increase

// // x = 6, y = 5
// 🧠 FINAL SUMMARY (Lock This In Your Brain)
// "33" → number → works
// "hitesh" → number → NaN
// "" → false
// "anything" → true
// "1" + 2 → string
// 1 + 2 + "2" → "32"
// +true → 1

